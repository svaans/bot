# Copia a config/claves.env y rellena (nunca subas claves.env al repositorio).
# Lista exhaustiva de variables: ``ConfigManager.load_from_env()`` en config/config_manager.py
# (clase Config + cuerpo de load_from_env). Muchas son opcionales y toman default de
# DevelopmentConfig / ProductionConfig según BOT_ENV (por defecto: development → paper).
BINANCE_API_KEY=
BINANCE_API_SECRET=
# false/omitido en dev = simulado (paper). Para órdenes reales: MODO_REAL=true
# (requiere claves) o BOT_ENV=production, o bien MODO_OPERATIVO=real
MODO_REAL=False
# SYMBOLS=BTC/USDT,ETH/USDT   # si omites, development/production usan estos spot USDT por defecto
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
MODO_TEST_NOTIFICADOR=false
TELEGRAM_PARSE_MODE=Markdown
LOG_LEVEL=WARNING

# Opcionales (operación avanzada):
# RISK_KILL_SWITCH_MAX_CONSECUTIVE_LOSSES=5   # racha de pérdidas consecutivas para activar kill switch (0 desactiva ese criterio)
# ALERT_NOTIFY_RATE_LIMIT_ENABLED=true        # false desactiva rate limit en eventos notify del EventBus
# ALERT_NOTIFY_MIN_INTERVAL_CRITICAL_SEC=60   # mínimo entre dos CRITICAL con el mismo operation_id (o mismo mensaje)
# ALERT_NOTIFY_MIN_INTERVAL_ERROR_SEC=45      # igual para ERROR
# ALERT_NOTIFY_THROTTLE_MAX_KEYS=2048         # tope de claves en memoria para el limitador
# Notificaciones: Telegram = core/notification_manager (cola). EventBus ``notify`` +
#   observability/AlertDispatcher → Discord/Slack/Prometheus; rate limit solo CRITICAL/ERROR.
#   Dedup opcional: pasar meta con dedup_key al NotificationManager desde el caller.
# HANDLER_TIMEOUT=180.0       # default en development/config (DataFeed); bajar solo para tests; subir si aún ves handler.timeout
# CLOCK_DRIFT_MAX_SECONDS=10.0  # segundos de desfase local vs Binance antes de marcar fallo de reloj (default 10)
# CLOCK_DRIFT_FORCE_PAPER=false # default: no bajar a simulado por reloj; true = si falla el drift, modo papel (antiguo comportamiento)
# BINANCE_SYNC_SYSTEM_TIME=auto    # Sincroniza el reloj del SO con Binance al arranque.
#                                  # Valores: off | auto (default; solo sincroniza si el proceso ya es admin)
#                                  #          | elevate (dispara UAC una vez y ejecuta w32tm /resync con admin)
# HOT_RELOAD_ENABLED=               # Auto-restart al cambiar ficheros. Por defecto se
#                                  # DESACTIVA cuando MODO_REAL=true (evita reinicios
#                                  # espurios disparados por IDE/antivirus/indexadores
#                                  # en mitad de una orden). Valores: true | false.
#                                  # Sin definir: auto (on en paper, off en real).
# TRADER_BUFFER_ISOLATED=true
# PROCESAR_VELA_STRICT_CLOSED=true
# ENTRADA_DEDUPE_POR_VELA=true   # false permite repetir candidatura misma vela+TF+lado (tests / depuración)
# ORDENES_DB_PATH=ordenes_reales/ordenes.db   # relativo → raíz del repo; omitir = default <repo>/ordenes_reales/ordenes.db
