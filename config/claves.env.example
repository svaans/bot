# Copia a config/claves.env y rellena (nunca subas claves.env al repositorio).
# Lista exhaustiva de variables: ``ConfigManager.load_from_env()`` en config/config_manager.py
# (clase Config + cuerpo de load_from_env). Muchas son opcionales y toman default de
# DevelopmentConfig / ProductionConfig según BOT_ENV.
BINANCE_API_KEY=
BINANCE_API_SECRET=
MODO_REAL=False
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
MODO_TEST_NOTIFICADOR=false
TELEGRAM_PARSE_MODE=Markdown
LOG_LEVEL=WARNING

# Opcionales (operación avanzada):
# RISK_KILL_SWITCH_MAX_CONSECUTIVE_LOSSES=5   # racha de pérdidas consecutivas para activar kill switch (0 desactiva ese criterio)
# ALERT_NOTIFY_RATE_LIMIT_ENABLED=true        # false desactiva rate limit en eventos notify del EventBus
# ALERT_NOTIFY_MIN_INTERVAL_CRITICAL_SEC=60   # mínimo entre dos CRITICAL con el mismo operation_id (o mismo mensaje)
# ALERT_NOTIFY_MIN_INTERVAL_ERROR_SEC=45      # igual para ERROR
# ALERT_NOTIFY_THROTTLE_MAX_KEYS=2048         # tope de claves en memoria para el limitador
# Notificaciones: Telegram = core/notification_manager (cola). EventBus ``notify`` +
#   observability/AlertDispatcher → Discord/Slack/Prometheus; rate limit solo CRITICAL/ERROR.
#   Dedup opcional: pasar meta con dedup_key al NotificationManager desde el caller.
# HANDLER_TIMEOUT=12.0          # segundos máx. por vela en el DataFeed (44+ estrategias / persistencia → subir si ves handler.timeout)
# CLOCK_DRIFT_MAX_SECONDS=2.0   # si el reloj va muy desincronizado, el arranque pasa a modo papel
# TRADER_BUFFER_ISOLATED=true
# PROCESAR_VELA_STRICT_CLOSED=true
# ENTRADA_DEDUPE_POR_VELA=true   # false permite repetir candidatura misma vela+TF+lado (tests / depuración)
