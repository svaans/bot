import os
import glob
import json
from collections import defaultdict
import pandas as pd
from core.pesos import gestor_pesos



def _cargar_operaciones(carpeta: str) -> pd.DataFrame:
    """Devuelve todas las operaciones almacenadas en ``carpeta``.

    Busca archivos ``.parquet`` y los concatena en un solo DataFrame.
    Si no hay archivos válidos se devuelve un DataFrame vacío.
    """
    if not os.path.exists(carpeta):
        return pd.DataFrame()

    dataframes = []
    for archivo in glob.glob(os.path.join(carpeta, "*.parquet")):
        try:
            df = pd.read_parquet(archivo)
            dataframes.append(df)
        except Exception as e:
            print(f"⚠️ Error leyendo {archivo}: {e}")

    return pd.concat(dataframes, ignore_index=True) if dataframes else pd.DataFrame()


def _extraer_estrategias(valor):
    if isinstance(valor, dict):
        return valor
    if not isinstance(valor, str):
        return {}
    try:
        return json.loads(valor.replace("'", '"'))
    except json.JSONDecodeError:
        return {}


def analizar_operaciones(
    carpeta_reales: str = "ordenes_reales",
    carpeta_simuladas: str = "ordenes_simuladas",
) -> pd.DataFrame:
    """Genera métricas por estrategia analizando todas las operaciones."""

    df_reales = _cargar_operaciones(carpeta_reales)
    df_sim = _cargar_operaciones(carpeta_simuladas)
    df = pd.concat([df_reales, df_sim], ignore_index=True)
    if df.empty:
        return pd.DataFrame()

    pesos = gestor_pesos.pesos
    stats = defaultdict(lambda: {
        "nombre": "",
        "activaciones": 0,
        "participaciones_en_operacion": 0,
        "ganadas": 0,
        "perdidas": 0,
        "rentabilidad_total": 0.0,
        "peso_total": 0.0,
    })

    for _, fila in df.iterrows():
        estrategias = _extraer_estrategias(fila.get("estrategias_activas", {}))
        retorno = float(fila.get("retorno_total", 0))
        symbol = fila.get("symbol", "")
        ganada = retorno > 0

        for nombre, activa in estrategias.items():
            if not activa:
                continue
            s = stats[nombre]
            s["nombre"] = nombre
            s["activaciones"] += 1
            s["participaciones_en_operacion"] += 1
            if ganada:
                s["ganadas"] += 1
            else:
                s["perdidas"] += 1
            s["rentabilidad_total"] += retorno
            peso = pesos.get(symbol, {}).get(nombre)
            if peso is not None:
                s["peso_total"] += peso

    resultados = []
    for nombre, info in stats.items():
        total = info["participaciones_en_operacion"] or 1
        winrate = (info["ganadas"] / total) * 100
        promedio = info["rentabilidad_total"] / total
        peso_promedio = info["peso_total"] / info["activaciones"] if info["activaciones"] else 0
        resultados.append({
            "nombre": nombre,
            "activaciones": info["activaciones"],
            "participaciones_en_operacion": info["participaciones_en_operacion"],
            "ganadas": info["ganadas"],
            "perdidas": info["perdidas"],
            "winrate": round(winrate, 2),
            "rentabilidad_total": round(info["rentabilidad_total"], 6),
            "media_rentabilidad": round(promedio, 6),
            "peso_promedio": round(peso_promedio, 3),
        })

    return pd.DataFrame(resultados).sort_values(by="rentabilidad_total", ascending=False)


if __name__ == "__main__":
    tabla = analizar_operaciones()
    if tabla.empty:
        print("Sin operaciones para analizar")
    else:
        print(tabla.to_string(index=False))